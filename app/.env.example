# Copie ce fichier en ".env" (dans le dossier app/) et remplis avec les valeurs
# de ton projet Supabase : menu "Project Settings" > "API".
#
# VITE_SUPABASE_URL      = le champ "Project URL"
# VITE_SUPABASE_ANON_KEY = la clé "anon public" (publique, sans danger côté site)
#
# NE JAMAIS mettre ici la clé "service_role" (secrète).

VITE_SUPABASE_URL=https://ton-projet.supabase.co
VITE_SUPABASE_ANON_KEY=colle-ici-ta-cle-anon-public
